{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "allowJs": false,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "baseUrl": "./",
        "forceConsistentCasingInFileNames": true,
        // Specify library type definitions to be included in the compilation.
        // "lib": ["DOM", "DOM.Iterable", "ES2023"],
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "target": "ES2022",
        "module": "ESNext",
        // Respects package.json's "exports" conditions.
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "noImplicitAny": true,
        "preserveConstEnums": true,
        "removeComments": true,
        "sourceMap": false,
        
        "resolveJsonModule": true,
        "typeRoots": [  
            "./src/types", 
            "./node_modules/@types"
        ],
        "paths": {
            "@shared/*": ["./src/shared/*"],
            "@landsat-explorer/*": ["./src/landsat-explorer/*"],
            "@sentinel2-explorer/*": ["./src/sentinel-2-explorer/*"],
            "@landcover-explorer/*": ["./src/landcover-explorer/*"],
            "@spectral-sampling-tool/*": ["./src/spectral-sampling-tool/*"],
            "@typing/*": ["./src/types/*"]
        }
    },
    "exclude": [
        "**/node_modules", 
        "**/.*/"
    ],
    "include": [
        "./src/**/**/*", "public/__tests__"    
    ]
}